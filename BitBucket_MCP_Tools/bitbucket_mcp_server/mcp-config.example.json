        "get_repository_readme",
        "list_pull_requests",
        "get_pull_request_details",
        "get_pull_request_comments",
        "list_repository_contributors",
        "search_repository_files",
        "get_repository_tags"
      ],
      "env": {},
      "disabled": false
    }
  }
}
