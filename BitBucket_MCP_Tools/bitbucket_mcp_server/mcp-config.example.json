      "args": [
        "D:/BitBucket_MCP_Tools/bitbucket_mcp_server/src/server.py"
      ],
      "description": "Read-only access to Bitbucket repositories",
      "capabilities": [
        "list_repositories",
        "get_repository_details",
        "list_branches",
        "list_commits",
