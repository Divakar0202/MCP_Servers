POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DEFAULT_DATABASE=postgres

# Absolute or relative path to external documentation folder.
# Example (Windows): D:/documentation
# Example (Linux): /opt/docs/documentation
DOCUMENTATION_PATH=../documentation

# Maximum number of rows returned from ad-hoc query tools.
MAX_RETURNED_ROWS=100
